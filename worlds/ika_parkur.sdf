    <!--
         ==========================================================================
          S6.8  KAYAR ENGEL
          1.0 m blade, 20 cm/s, 4.0 m peak to peak so it fully clears the 3 m road on both sides. Motion comes from the kayar_engel_driver node; without it the blade sits still.
         ==========================================================================
    -->
    <model name="kayar_engel">
      <pose>-15 13 0 0 0 0</pose>
      <link name="anchor">
        <pose>0 -2.75 0.45 0 0 0</pose>
        <inertial>
          <mass>50</mass>
          <inertia>
            <ixx>5</ixx>
            <iyy>5</iyy>
            <izz>5</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="post_a_col">
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.25 0.25 0.9</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1</mu>
                <mu2>1</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1000000</kp>
                <kd>1</kd>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name="post_a_vis">
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.25 0.25 0.9</size>
            </box>
          </geometry>
          <material>
            <ambient>0.22 0.22 0.24 1</ambient>
            <diffuse>0.22 0.22 0.24 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
      <joint name="anchor_fixed" type="fixed">
        <parent>world</parent>
        <child>anchor</child>
      </joint>
      <link name="rail">
        <pose>0 0 0.01 0 0 0</pose>
        <inertial>
          <mass>1</mass>
          <inertia>
            <ixx>1</ixx>
            <iyy>1</iyy>
            <izz>1</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="rail_vis">
          <geometry>
            <box>
              <size>0.12 5.5 0.02</size>
            </box>
          </geometry>
          <material>
            <ambient>0.22 0.22 0.24 1</ambient>
            <diffuse>0.22 0.22 0.24 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <visual name="post_b_vis">
          <pose>0 2.75 0.44 0 0 0</pose>
          <geometry>
            <box>
              <size>0.25 0.25 0.9</size>
            </box>
          </geometry>
          <material>
            <ambient>0.22 0.22 0.24 1</ambient>
            <diffuse>0.22 0.22 0.24 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
        <collision name="post_b_col">
          <pose>0 2.75 0.44 0 0 0</pose>
          <geometry>
            <box>
              <size>0.25 0.25 0.9</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.6</mu>
                <mu2>0.6</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1000000</kp>
                <kd>1</kd>
              </ode>
            </contact>
          </surface>
        </collision>
      </link>
      <joint name="rail_fixed" type="fixed">
        <parent>anchor</parent>
        <child>rail</child>
      </joint>
      <link name="blade">
        <pose>0 0 0.42 0 0 0</pose>
        <inertial>
          <mass>40</mass>
          <inertia>
            <ixx>5.466667</ixx>
            <iyy>2.266667</iyy>
            <izz>3.466667</izz>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="blade_col">
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.2 1 0.8</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.6</mu>
                <mu2>0.6</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1000000</kp>
                <kd>1</kd>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name="blade_vis">
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.2 1 0.8</size>
            </box>
          </geometry>
          <material>
            <ambient>0.85 0.72 0.1 1</ambient>
            <diffuse>0.85 0.72 0.1 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
      <joint name="slide" type="prismatic">
        <parent>anchor</parent>
        <child>blade</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-2.05</lower>
            <upper>2.05</upper>
            <effort>100000</effort>
            <velocity>2</velocity>
          </limit>
          <dynamics>
            <damping>0</damping>
            <friction>0</friction>
          </dynamics>
        </axis>
      </joint>
      <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        <joint_name>slide</joint_name>
      </plugin>
      <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
        <joint_name>slide</joint_name>
        <!-- use_force_commands false sets joint velocity directly, which is what makes the 20 cm/s exact. -->
        <use_force_commands>false</use_force_commands>
        <topic>/kayar_engel/cmd_vel</topic>
      </plugin>
    </model>
